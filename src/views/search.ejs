<div class="products">
    <%- include('components/breadCrumb', { page: 'search' }) %>
    <span>Mostrando un total de <%= products.length %> productos</span>
    <div class="list" <% if (products.length === 0) { %> style="display: flex; overflow: hidden;" <% } %>>
        <% if (products.length === 0) { %>
            <h2>Lo sentimos... No se encontraron productos en la lista.</h2>
        <% } else { %>
            <% products.forEach(product => { %>
                <%- include('components/productCard', { 
                    id: product.id,
                    name: product.name,
                    image: "/images/products/" + product.category + "/" + product.image,
                    points: product.points,
                    category: product.category
                }) %>
            <% }) %>
        <% } %>
    </div>
</div>

<script src="/js/dropdown.js"></script>
<script src="/js/search.js"></script>