<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Ecommerce</title>

    <link rel="stylesheet" href="/css/layouts/header.css">
    <link rel="stylesheet" href="/css/views/login-register.css">
    <link rel="stylesheet" href="/css/layouts/footer.css">
</head>
<body>
    <%- include('layouts/header', { loggedIn: loggedIn }) %>
    <main>
        <div>
            <h2>¡Bienvenido!</h2>
            <input type="text" name="username" placeholder="Tu nombre de usuario" autocomplete="off">
            <input type="text" name="password" placeholder="Tu contraseña">

            <a class="button-submit" href="/">Iniciar Sesión</a>
            <h5>¿No tienes cuenta? <a href="/register">Regístrate</a></h5>
        </div>
    </main>
    <%- include('layouts/footer') %>
</body>
</html>